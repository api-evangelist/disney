        {
          "id": "09ddcafe-0c2c-450e-b2db-e7d9b3b9e389",
          "name": "Disney API List Characters",
          "request": {
            "name": "Disney API List Characters",
            "description": {
              "content": "Returns a paginated list of Disney characters. Supports paging via `page` and `pageSize`, and supports filtering by any of the character schema fields (`name`, `films`, `shortFilms`, `tvShows`, `videoGames`, `parkAttractions`, `allies`, `enemies`, `alignment`). Filter values are matched as case-insensitive substrings on the server side. When more than one record matches, `data` is an array of character records; when a single record matches, `data` is the record itself.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "character"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "page",
                  "value": "1",
                  "description": "1-based page index. Defaults to 1."
                },
                {
                  "disabled": false,
                  "key": "pageSize",
                  "value": "50",
                  "description": "Number of records per page. Defaults to 50."
                },
                {
                  "disabled": false,
                  "key": "name",
                  "value": "<string>",
                  "description": "Case-insensitive substring filter against the `name` field."
                },
                {
                  "disabled": false,
                  "key": "films",
                  "value": "<string>",
                  "description": "Case-insensitive substring filter against the `films` array."
                },
                {
                  "disabled": false,
                  "key": "shortFilms",
                  "value": "<string>",
                  "description": "Case-insensitive substring filter against the `shortFilms` array."
                },
                {
                  "disabled": false,
                  "key": "tvShows",
                  "value": "<string>",
                  "description": "Case-insensitive substring filter against the `tvShows` array."
                },
                {
                  "disabled": false,
                  "key": "videoGames",
                  "value": "<string>",
                  "description": "Case-insensitive substring filter against the `videoGames` array."
                },
                {
                  "disabled": false,
                  "key": "parkAttractions",
                  "value": "<string>",
                  "description": "Case-insensitive substring filter against the `parkAttractions` array."
                },
                {
                  "disabled": false,
                  "key": "allies",
                  "value": "<string>",
                  "description": "Case-insensitive substring filter against the `allies` array."
                },
                {
                  "disabled": false,
                  "key": "enemies",
                  "value": "<string>",
                  "description": "Case-insensitive substring filter against the `enemies` array."
                },
                {
                  "disabled": false,
                  "key": "alignment",
                  "value": "<string>",
                  "description": "Case-insensitive substring filter against the `alignment` field."
