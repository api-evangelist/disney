    },
    "data": {
      "description": "Either an array of Character, a single Character, or an empty array.",
      "oneOf": [
        {
          "type": "array",
          "items": {
            "$ref": "https://raw.githubusercontent.com/api-evangelist/disney/refs/heads/main/json-structure/disney-character-structure.json"
          }
        },
        {
          "$ref": "https://raw.githubusercontent.com/api-evangelist/disney/refs/heads/main/json-structure/disney-character-structure.json"
        }
      ]
    }
  }
